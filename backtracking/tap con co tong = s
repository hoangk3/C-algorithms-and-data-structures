// ==================== SOLUTION ====================
int n,s;
vector<ll>A;
ll tong;
void ppz( ll i)
{
    if ( i > n)
    {
        for ( auto p : A)
        {
            tong += p;
        }
        if (tong == s)
            {
                for( auto x : A) cout << x << " ";
                cout << endl;
            }
        tong = 0;
        return;
    }
    A.push_back(i);
    ppz(i+1);
    A.pop_back();
    ppz(i+1);
}
int main()
{
    cin >> n >> s;
    ppz(1);
}
